               /aws-dynamodb-to-aurora-postgresql-replication/image-20220507215243982_huf82ea1bfca9866080d595a8babc53f3e_91583_1200x1200_fit_q75_h2_lanczos_3.webp 1200w&#34;
               src=&#34;/aws-dynamodb-to-aurora-postgresql-replication/image-20220507215243982_huf82ea1bfca9866080d595a8babc53f3e_91583_3c6bc3285e3a195008a4dec44e124620.webp&#34;
