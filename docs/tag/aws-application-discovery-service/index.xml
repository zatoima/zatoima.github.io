&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;&lt;span class=&#34;o&#34;&gt;[&lt;/span&gt;ec2-user@bastin ads&lt;span class=&#34;o&#34;&gt;]&lt;/span&gt;$ ls -l
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;total &lt;span class=&#34;m&#34;&gt;37536&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;-rw-rw-r-- &lt;span class=&#34;m&#34;&gt;1&lt;/span&gt; ec2-user ec2-user &lt;span class=&#34;m&#34;&gt;38433031&lt;/span&gt; Oct  &lt;span class=&#34;m&#34;&gt;2&lt;/span&gt; 21:16 aws-discovery-agent.tar.gz
