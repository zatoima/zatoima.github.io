  &lt;div class=&#34;d-flex justify-content-center&#34;&gt;
    &lt;div class=&#34;w-100&#34; &gt;&lt;img alt=&#34;image-20211017140239780&#34; srcset=&#34;
               /speedtest-cli-visualize-wifi-env/image-20211017140239780_huedc7eb62b8f3731ec059ea964b3ebea2_31787_fdbb7321850eaf07d9a6c186a9f49fbe.png 400w,
               /speedtest-cli-visualize-wifi-env/image-20211017140239780_huedc7eb62b8f3731ec059ea964b3ebea2_31787_5eca625afef7881559e083466e43908f.png 760w,
