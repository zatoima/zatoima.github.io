               /speedtest-cli-visualize-wifi-env/image-20211020085753925_hue0426e63f25d84ce135b77a448348ab7_79390_19d269b863e7a83baa472196c52e073c.png 400w,
               /speedtest-cli-visualize-wifi-env/image-20211020085753925_hue0426e63f25d84ce135b77a448348ab7_79390_988ca7bd9ddb192cdfac6ca71d58c364.png 760w,
               /speedtest-cli-visualize-wifi-env/image-20211020085753925_hue0426e63f25d84ce135b77a448348ab7_79390_1200x1200_fit_lanczos_3.png 1200w&#34;
               src=&#34;/speedtest-cli-visualize-wifi-env/image-20211020085753925_hue0426e63f25d84ce135b77a448348ab7_79390_19d269b863e7a83baa472196c52e073c.png&#34;
