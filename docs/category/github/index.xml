               /image-20200109181522146_hu88f34c8709d26a443a4bc997275880ab_12423_93922d5c50a1ccd85589dad45d922403.png 400w,
               /image-20200109181522146_hu88f34c8709d26a443a4bc997275880ab_12423_068916d2fa6bcc742a81de3a2f537c48.png 760w,
               /image-20200109181522146_hu88f34c8709d26a443a4bc997275880ab_12423_1200x1200_fit_lanczos_3.png 1200w&#34;
               src=&#34;/image-20200109181522146_hu88f34c8709d26a443a4bc997275880ab_12423_93922d5c50a1ccd85589dad45d922403.png&#34;
               width=&#34;760&#34;
               height=&#34;187&#34;
               loading=&#34;lazy&#34; data-zoomable /&gt;&lt;/div&gt;
  &lt;/div&gt;&lt;/figure&gt;
&lt;/p&gt;
</description>
